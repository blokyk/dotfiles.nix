
emulate -L zsh
local _z4h_fmt
if [[ -n $SSH_CONNECTION || $P9K_SSH == 1 ]]; then
zstyle -s :z4h:term-title:ssh   preexec _z4h_fmt || _z4h_fmt='%n@%m: ${1//\%/%%}'
else
zstyle -s :z4h:term-title:local preexec _z4h_fmt || _z4h_fmt='${1//\%/%%}'
fi
-z4h-iterm2-preexec
[[ -z $_z4h_fmt ]] || -z4h-set-term-title $_z4h_fmt "$@"
